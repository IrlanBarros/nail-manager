<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15.0" styleClass="form-container" stylesheets="@../../asset/css/global.css, @../asset/css/forms.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="presentation.controller.components.AppointmentFormController"
      prefWidth="400.0">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="page-title" text="Novo Agendamento" />

    <VBox spacing="5.0">
        <Label text="Cliente" styleClass="form-label" />
        <ComboBox fx:id="customerComboBox" maxWidth="Infinity" promptText="Select a customer" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Serviços (Selecione um ou mais)" styleClass="form-label" />
        <ListView fx:id="servicesListView" prefHeight="100.0" />
    </VBox>

    <HBox spacing="10.0">
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Data" styleClass="form-label" />
            <DatePicker fx:id="datePicker" maxWidth="Infinity" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Hora (HH:mm)" styleClass="form-label" />
            <TextField fx:id="timeField" prefWidth="100.0" promptText="14:30" />
        </VBox>
    </HBox>

    <VBox spacing="5.0">
        <Label text="Descrição" styleClass="form-label" />
        <TextField fx:id="descriptionField" promptText="Optional details..." />
    </VBox>

    <HBox spacing="15.0" alignment="CENTER_RIGHT" styleClass="form-actions-container">
        <Button onAction="#handleCancel" styleClass="secondary-btn" text="Cancelar" />
        <Button onAction="#handleSave" styleClass="save-btn" text="Salvar Agendamento" />
    </HBox>

</VBox>