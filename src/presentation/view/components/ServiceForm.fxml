<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="15.0" styleClass="form-container" stylesheets="@../../asset/css/global.css, @../asset/css/forms.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="presentation.controller.components.ServiceFormController">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="page-title" text="Detalhes do Serviço" />

    <VBox spacing="5.0">
        <Label styleClass="form-label" text="Nome do serviço *" />
        <TextField fx:id="nameField" promptText="e.g. Manicure" styleClass="search-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label styleClass="form-label" text="Descrição" />
        <TextField fx:id="descriptionField" promptText="Brief description..." styleClass="search-field" />
    </VBox>

    <VBox spacing="5.0">
        <Label styleClass="form-label" text="Preço (R$) *" />
        <TextField fx:id="priceField" promptText="0.00" styleClass="search-field" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0" styleClass="form-actions-container">
        <Button onAction="#handleCancel" styleClass="secondary-btn" text="Cancelar" />
        <Button onAction="#handleSave" styleClass="save-btn" text="Salvar Serviço" />
    </HBox>

</VBox>