<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<VBox spacing="30.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controller.ReportsController">
   <children>
      
      <VBox spacing="10.0" styleClass="card">
         <children>
            <Label styleClass="card-title" text="Faturamento Mensal" />
            <LineChart fx:id="faturamentoChart" prefHeight="300.0">
              <xAxis>
                <CategoryAxis side="BOTTOM" />
              </xAxis>
              <yAxis>
                <NumberAxis side="LEFT" />
              </yAxis>
            </LineChart>
         </children>
      </VBox>

      <VBox spacing="10.0" styleClass="card">
         <children>
            <Label styleClass="card-title" text="Serviços Mais Realizados" />
            <BarChart fx:id="servicosChart" prefHeight="300.0">
              <xAxis>
                <CategoryAxis side="BOTTOM" />
              </xAxis>
              <yAxis>
                <NumberAxis side="LEFT" />
              </yAxis>
            </BarChart>
         </children>
      </VBox>
      
   </children>
</VBox>