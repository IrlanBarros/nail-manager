<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controller.LoginController">
   <stylesheets>
      <URL value="@../asset/css/global.css" />
      <URL value="@../asset/css/login.css" />
   </stylesheets>
   <children>
      <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" prefWidth="640.0" styleClass="sidebar-branding" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="title-label" text="Nail Manager" />
                  <Label styleClass="subtitle-label" text="Sistema Integrado de Gestão">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>

            <VBox alignment="CENTER" prefWidth="640.0" styleClass="form-container" HBox.hgrow="ALWAYS">
               <children>
                  <VBox maxWidth="400.0" prefWidth="400.0" spacing="20.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="welcome-label" text="Bem-vindo de volta" />
                              <Label styleClass="instruction-label" text="Por favor, insira suas credenciais para acessar." />
                           </children>
                           <VBox.margin>
                              <Insets bottom="20.0" />
                           </VBox.margin>
                        </VBox>

                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="E-mail" />
                              <TextField fx:id="emailField" promptText="Digite o seu e-mail" />
                           </children>
                        </VBox>

                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="field-label" text="Senha" />
                              <PasswordField fx:id="passwordField" promptText="Digite a sua senha" />
                           </children>
                        </VBox>

                        <Button mnemonicParsing="false" onAction="#handleLogin" prefWidth="400.0" styleClass="login-button" text="Entrar no Sistema">
                           <VBox.margin>
                              <Insets top="20.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                     <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                     </padding>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>