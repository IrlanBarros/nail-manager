<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" styleClass="main-container" stylesheets="@../style/home.css" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="presentation.controller.CustomerController">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Customers" styleClass="page-title" />

    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <Button text="+ Novo Cliente" onAction="#handleNewCustomer" styleClass="action-btn" />
        <TextField fx:id="searchField" promptText="Search customer..." prefWidth="300.0" styleClass="search-field" />
        <Button text="Pesquisar" onAction="#handleSearch" styleClass="action-btn" />
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" prefWidth="200.0" text="Nome" />
            <TableColumn fx:id="colPhone" prefWidth="150.0" text="Telefone" />
            <TableColumn fx:id="colActions" prefWidth="120.0" text="Ações" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>