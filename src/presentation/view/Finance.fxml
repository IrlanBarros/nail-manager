<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" styleClass="page-scroll-pane" stylesheets="@../asset/css/global.css, @../asset/css/layout.css" 
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="presentation.controller.FinanceController">
    <content>
        <VBox spacing="20.0" styleClass="page-content">
            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Período:" styleClass="filter-label" />
                        <ComboBox fx:id="comboPeriod" prefWidth="150.0" promptText="Mês Atual" />
                        <DatePicker fx:id="dateStart" prefWidth="130.0" />
                        <DatePicker fx:id="dateEnd" prefWidth="130.0" />
                        <Button text="Filtrar" onAction="#handleFilter" styleClass="filter-btn" />
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox styleClass="card-panel" HBox.hgrow="ALWAYS">
                            <Label text="SALDO" styleClass="card-title" />
                            <Label fx:id="lblTotal" text="R$ 2.350,00" styleClass="card-value" />
                        </VBox>
                        <VBox styleClass="card-panel" HBox.hgrow="ALWAYS">
                            <Label text="ENTRADAS" styleClass="card-title" />
                            <Label fx:id="lblTotalEntry" text="R$ 4.200,00" styleClass="card-value-green" />
                        </VBox>
                        <VBox styleClass="card-panel" HBox.hgrow="ALWAYS">
                            <Label text="SAÍDAS" styleClass="card-title" />
                            <Label fx:id="lblTotalExpense" text="R$ 1.850,00" styleClass="card-value-red" />
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="10.0">
                    <Button text="Movimentações" styleClass="section-btn" />
                </HBox>

                <TableView fx:id="tableFinance" prefHeight="400.0">
                    <columns>
                        <TableColumn fx:id="colType" text="Tipo" prefWidth="80.0" />
                        <TableColumn fx:id="colData" text="Data" prefWidth="100.0" />
                        <TableColumn fx:id="colDescription" text="Descrição" prefWidth="300.0" />
                        <TableColumn fx:id="colOrigin" text="Origem" prefWidth="150.0" />
                        <TableColumn fx:id="colValue" text="Valor" prefWidth="120.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Button text="+ Nova Transação" onAction="#handleNewTransaction" styleClass="action-btn" />
            </children>
        </VBox>
    </content>
</ScrollPane>