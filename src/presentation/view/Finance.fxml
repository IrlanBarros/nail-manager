<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controller.FinanceController">
    <content>
        <VBox spacing="20.0" style="-fx-padding: 30;">
            <children>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Período:" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="comboPeriod" prefWidth="150.0" promptText="Mês Atual" />
                        <DatePicker fx:id="dateStart" prefWidth="130.0" />
                        <DatePicker fx:id="dateEnd" prefWidth="130.0" />
                        <Button text="Filtrar" style="-fx-background-color: #2b2b2b; -fx-text-fill: white;" />
                    </children>
                </HBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox style="-fx-background-color: #2B2D42; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="SALDO" style="-fx-text-fill: white; -fx-font-size: 12;" />
                            <Label fx:id="lblTotal" text="R$ 2.350,00" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox style="-fx-background-color: #2B2D42; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="ENTRADAS" style="-fx-text-fill: white; -fx-font-size: 12;" />
                            <Label fx:id="lblTotalEntry" text="R$ 4.200,00" style="-fx-text-fill: #4CAF50; -fx-font-size: 20; -fx-font-weight: bold;" />
                        </VBox>
                        <VBox style="-fx-background-color: #2B2D42; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label text="SAÍDAS" style="-fx-text-fill: white; -fx-font-size: 12;" />
                            <Label fx:id="lblTotalExpense" text="R$ 1.850,00" style="-fx-text-fill: #EF233C; -fx-font-size: 20; -fx-font-weight: bold;" />
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="10.0">
                    <Button text="Movimentações" style="-fx-background-color: #ddd; -fx-font-weight: bold;" />
                </HBox>

                <TableView fx:id="tableFinance" prefHeight="400.0">
                    <columns>
                        <TableColumn fx:id="colType" text="Tipo" prefWidth="80.0" />
                        <TableColumn fx:id="colData" text="Data" prefWidth="100.0" />
                        <TableColumn fx:id="colDescription" text="Descrição" prefWidth="300.0" />
                        <TableColumn fx:id="colOrigin" text="Origem" prefWidth="150.0" />
                        <TableColumn fx:id="colValue" text="Valor" prefWidth="120.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Button text="+ Nova Despesa" style="-fx-background-color: transparent; -fx-text-fill: #2b2b2b; -fx-border-color: #2b2b2b; -fx-border-radius: 5;" />
            </children>
        </VBox>
    </content>
</ScrollPane>