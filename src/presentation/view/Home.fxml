<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@../style/home.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controller.HomeController">
    <center>
        <VBox spacing="20.0" styleClass="main-content">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            
            <HBox spacing="10.0" styleClass="tab-container">
                <Button fx:id="btnTabTodos" onAction="#showTodos" styleClass="tab-btn, active-tab" text="Todos" />
                <Label styleClass="tab-separator" text="|" />
                
                <Button fx:id="btnTabAgendamentos" onAction="#showAgendamentos" styleClass="tab-btn" text="Agendamentos" />
                <Label styleClass="tab-separator" text="|" />
                
                <Button fx:id="btnTabAtendimentos" onAction="#showAtendimentos" styleClass="tab-btn" text="Atendimentos" />
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                
                <TableView fx:id="tabelaAgendamentos">
                    <columns>
                        <TableColumn fx:id="colAgendamentoCliente" prefWidth="200.0" text="Cliente" />
                        <TableColumn fx:id="colAgendamentoData" prefWidth="150.0" text="Data e hora" />
                        <TableColumn fx:id="colAgendamentoServicos" prefWidth="250.0" text="Serviços" />
                        <TableColumn fx:id="colAgendamentoStatus" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="colAcaoAgendamento" prefWidth="100.0" text="Actions" />
                    </columns>
                   <columnResizePolicy>
                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                   </columnResizePolicy>
                </TableView>

                <TableView fx:id="tabelaAtendimentos" visible="false">
                    <columns>
                        <TableColumn fx:id="colAtendimentoCliente" prefWidth="180.0" text="Cliente" />
                        <TableColumn fx:id="colAtendimentoData" prefWidth="150.0" text="Data e hora" />
                        <TableColumn fx:id="colAtendimentoServicos" prefWidth="200.0" text="Serviços" />
                        <TableColumn fx:id="colAtendimentoValor" prefWidth="100.0" text="Valor" />
                        <TableColumn fx:id="colAtendimentoPagamento" prefWidth="150.0" text="Forma de pagamento" />
                    </columns>
                   <columnResizePolicy>
                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                   </columnResizePolicy>
                </TableView>
                
            </StackPane>

            <HBox spacing="15.0">
                <Button onAction="#handleNewAppointment" styleClass="action-btn" text="+ Novo agendamento" />
                <Button onAction="#handleRegisterAppointment" styleClass="action-btn" text="Registrar atendimento" />
            </HBox>
            
        </VBox>
    </center>
</BorderPane>